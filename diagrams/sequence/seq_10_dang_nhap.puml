@startuml seq_dang_nhap
skinparam defaultFontName Arial
skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipantBorderColor #3B82F6
skinparam sequenceParticipantBackgroundColor #DBEAFE
skinparam sequenceActorBorderColor #1D4ED8

title Dang Nhap He Thong

actor "Nguoi dung" as A
participant "LoginFrame\n(View)" as V
participant "UserController" as C
participant "UserService\n(Impl)" as S
participant "UserRepository" as R
participant "UserSessionContext" as CTX
participant "MainFrame" as MF
database "Database" as DB

A -> V: Nhap Username & Password
A -> V: Nhan "DANG NHAP" (hoac Enter)
V -> V: Kiem tra rong

alt Username hoac Password trong
  V -> A: JOptionPane "Vui long nhap day du thong tin!"
else Khong trong
  V -> V: Vo hieu hoa nut dang nhap\nbtnLogin.setEnabled(false)
  note right of V: Chay trong Thread rieng

  V -> C: handleLogin(username, password)
  C -> S: authenticate(username, password)
  S -> S: Ma hoa password (SHA-256)
  S -> R: findByUsername(username)
  R -> DB: SELECT * FROM User WHERE username=?
  DB --> R: User | null
  R --> S: user object

  alt User khong ton tai hoac password sai
    S --> C: return false
    C --> V: false
    V -> A: Hien thi loi "Sai tai khoan hoac mat khau!"
    V -> V: Bat lai nut dang nhap

  else Tai khoan bi khoa (IsActive = false)
    S --> C: return false
    C --> V: false
    V -> A: Hien thi loi "Tai khoan da bi vo hieu hoa"
    V -> V: Bat lai nut dang nhap

  else Dang nhap thanh cong
    S -> CTX: setCurrentUser(user)
    S --> C: return true
    C --> V: true
    V -> MF: new MainFrame(userId, roleName)
    V -> V: dispose() - dong LoginFrame
  end
end
@enduml
