@startuml seq_kiem_tra_promo
skinparam defaultFontName Arial
skinparam sequenceArrowThickness 2
skinparam roundcorner 8
skinparam sequenceParticipantBorderColor #3B82F6
skinparam sequenceParticipantBackgroundColor #DBEAFE
skinparam sequenceActorBorderColor #1D4ED8

title Kiem Tra & Ap Dung Ma Promo

actor "Nhan vien" as A
participant "PaymentPanel\n(View)" as V
participant "PromotionController" as C
participant "PromotionService\n(Impl)" as S
participant "PromotionRepository" as R
database "Database" as DB

A -> V: Nhap ma Promo
A -> V: Nhan "Ap dung"
V -> C: validatePromoCode(code, showTime)
C -> S: validatePromoCode(code, showTime)

S -> R: findByCode(code)
R -> DB: SELECT * FROM Promotion WHERE code=?
DB --> R: result
R --> S: Promotion (nullable)

alt Ma khong ton tai
  S --> C: throw IllegalArgumentException("Ma KM khong ton tai")
  C --> V: exception
  V -> A: Hien thi loi "Ma khuyen mai khong ton tai"

else Ma tim thay
  S -> S: Kiem tra ExpiryDate > today

  alt Da het han
    S --> C: throw IllegalArgumentException("Ma KM da het han")
    C --> V: exception
    V -> A: Hien thi loi "Ma khuyen mai da het han"

  else Con han
    S -> S: Kiem tra rang buoc phim / ngay trong tuan

    alt Khong dung phim dang chon
      S --> C: throw IllegalArgumentException("Ma KM khong ap dung cho phim nay")
      C --> V: exception
      V -> A: Hien thi loi "Ma KM khong ap dung cho phim nay"

    else Hop le hoan toan
      S -> S: calculateDiscount(promotion, subTotal)
      note right: tienGiam = subTotal x discountPercent%\nap dung cap MaxDiscountAmount
      S --> C: Promotion + discountAmount
      C --> V: discountAmount
      V -> A: Hien thi tien giam & tong tien moi
    end
  end
end
@enduml
