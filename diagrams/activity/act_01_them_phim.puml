@startuml act_them_phim
skinparam defaultFontName Arial
skinparam backgroundColor #F8FAFC
skinparam activityBackgroundColor #DBEAFE
skinparam activityBorderColor #3B82F6
skinparam arrowColor #1D4ED8
skinparam activityDiamondBackgroundColor #FEF9C3
skinparam activityDiamondBorderColor #CA8A04

title Thêm Phim Mới

start
:Admin mở màn hình Quản lý Phim;
:Nhấn nút "Thêm Phim mới";

repeat
  :Nhập thông tin phim\n(Tên phim, Thể loại, Thời lượng, Mô tả, Ngày khởi chiếu);
  if (Tên phim trống?) then (Có)
    :Hiển thị lỗi\n"Tên phim không được để trống";
  elseif (Thời lượng <= 0?) then (Có)
    :Hiển thị lỗi\n"Thời lượng không hợp lệ";
  elseif (Chưa chọn thể loại?) then (Có)
    :Hiển thị lỗi\n"Vui lòng chọn ít nhất 1 thể loại";
  elseif (Ngày chiếu sai định dạng?) then (Có)
    :Hiển thị lỗi\n"Ngày chiếu không đúng định dạng";
  else (Dữ liệu hợp lệ)
  endif
repeat while (Có lỗi nhập liệu?) is (Có) not (Không)

:Sinh ID phim mới;
:Nhấn "Lưu" / Gọi MovieController.addMovie();
:MovieService → MovieRepository → DB;
if (Lưu thành công?) then (Có)
  :Hiển thị "Thêm phim thành công!";
  :Cập nhật danh sách phim (loadTable);
else (Lỗi DB)
  :Hiển thị thông báo lỗi hệ thống;
endif

stop
@enduml
