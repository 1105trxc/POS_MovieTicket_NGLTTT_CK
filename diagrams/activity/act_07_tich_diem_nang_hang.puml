@startuml act_tich_diem_nang_hang
skinparam defaultFontName Arial
skinparam backgroundColor #F8FAFC
skinparam activityBackgroundColor #DBEAFE
skinparam activityBorderColor #3B82F6
skinparam arrowColor #1D4ED8
skinparam activityDiamondBackgroundColor #FEF9C3

title Tích Điểm & Tự Động Nâng Hạng

start
:Hệ thống nhận Invoice vừa thanh toán thành công;
:Lấy thông tin khách hàng từ Invoice;

if (Có khách hàng thành viên?) then (Không)
  :Bỏ qua - không tích điểm;
  stop
else (Có)
endif

:Tính điểm tích lũy\n= totalAmount × 5%;
:Cộng điểm vào Customer.rewardPoints;
:Cộng totalAmount vào Customer.totalSpent;
:Ghi PointHistory (loại: EARN);

:Kiểm tra ngưỡng Customer.totalSpent;
if (TotalSpent >= 5,000,000\nvà Tier hiện tại < GOLD?) then (Có)
  :Nâng hạng lên GOLD;
  :Cập nhật Customer.tier = GOLD;
elseif (TotalSpent >= 2,000,000\nvà Tier hiện tại < SILVER?) then (Có)
  :Nâng hạng lên SILVER;
  :Cập nhật Customer.tier = SILVER;
else (Không cần nâng hạng)
endif

:Lưu Customer cập nhật vào DB;
:Thông báo số điểm nhận được;

stop
@enduml
