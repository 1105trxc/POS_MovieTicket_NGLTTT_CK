@startuml act_kiem_tra_promo
skinparam defaultFontName Arial
skinparam backgroundColor #F8FAFC
skinparam activityBackgroundColor #DBEAFE
skinparam activityBorderColor #3B82F6
skinparam arrowColor #1D4ED8
skinparam activityDiamondBackgroundColor #FEF9C3

title Kiểm Tra & Áp Dụng Mã Promo

start
repeat
  :Nhân viên nhập mã Promo;
  if (Mã Promo trống?) then (Có)
    :Hiển thị lỗi\n"Vui lòng nhập mã khuyến mãi";
  elseif (Mã không tồn tại trong DB?) then (Có)
    :Hiển thị lỗi\n"Mã khuyến mãi không tồn tại";
  elseif (Mã đã hết hạn\n(today > ExpiryDate)?) then (Có)
    :Hiển thị lỗi\n"Mã khuyến mãi đã hết hạn";
  elseif (Mã không áp dụng\ncho phim đang chọn?) then (Có)
    :Hiển thị lỗi\n"Mã KM không áp dụng cho phim này";
  else (Hợp lệ)
  endif
repeat while (Mã không hợp lệ?) is (Có) not (Hợp lệ)

:Tính tiền giảm = subTotal × discountPercent%;
:Áp dụng giới hạn MaxDiscountAmount (nếu có);
:Hiển thị số tiền được giảm;
:Cập nhật tổng tiền cần thanh toán;

stop
@enduml
