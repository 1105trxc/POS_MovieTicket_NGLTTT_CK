@startuml act_tao_tai_khoan_staff
skinparam defaultFontName Arial
skinparam backgroundColor #F8FAFC
skinparam activityBackgroundColor #DBEAFE
skinparam activityBorderColor #3B82F6
skinparam arrowColor #1D4ED8
skinparam activityDiamondBackgroundColor #FEF9C3

title Admin Tạo Tài Khoản Cho Nhân Viên

start
:Admin mở màn hình Quản lý Tài Khoản;
:Nhấn nút tìm kiếm nhân viên (icon kính lúp);
:Chọn nhân viên từ StaffSelectionDialog;
:Hệ thống điền thông tin NV vào Form;

repeat
  :Nhập Username, Mật khẩu, chọn Vai trò (Role);
  if (Username trống?) then (Có)
    :Hiển thị lỗi\n"Username không được để trống";
  elseif (Mật khẩu trống?) then (Có)
    :Hiển thị lỗi\n"Mật khẩu không được để trống";
  else (Hợp lệ)
  endif
repeat while (Có lỗi?) is (Có) not (Không)

:Nhấn "Xác nhận";

:Gán Username, Password , Role cho User;
:Gọi UserController.updateUser();
:UserService → UserRepository → DB;
if (Thành công?) then (Có)
  :Hiển thị "Tạo tài khoản thành công!";
  :Reload bảng tài khoản;
else (Lỗi)
  :Hiển thị lỗi hệ thống;
endif

stop
@enduml
