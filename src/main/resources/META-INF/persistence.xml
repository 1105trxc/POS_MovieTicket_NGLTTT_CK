<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="CinemaPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entity classes -->
        <class>com.cinema.management.model.entity.Role</class>
        <class>com.cinema.management.model.entity.User</class>
        <class>com.cinema.management.model.entity.AuditLog</class>
        <class>com.cinema.management.model.entity.Movie</class>
        <class>com.cinema.management.model.entity.Genre</class>
        <class>com.cinema.management.model.entity.MovieGenre</class>
        <class>com.cinema.management.model.entity.Room</class>
        <class>com.cinema.management.model.entity.SeatType</class>
        <class>com.cinema.management.model.entity.Seat</class>
        <class>com.cinema.management.model.entity.ShowTime</class>
        <class>com.cinema.management.model.entity.Product</class>
        <class>com.cinema.management.model.entity.Customer</class>
        <class>com.cinema.management.model.entity.Promotion</class>
        <class>com.cinema.management.model.entity.Invoice</class>
        <class>com.cinema.management.model.entity.BookingSeat</class>
        <class>com.cinema.management.model.entity.BookingSeatId</class>
        <class>com.cinema.management.model.entity.SeatLock</class>
        <class>com.cinema.management.model.entity.SeatLockId</class>
        <class>com.cinema.management.model.entity.OrderDetail</class>
        <class>com.cinema.management.model.entity.OrderDetailId</class>
        <class>com.cinema.management.model.entity.Payment</class>
        <class>com.cinema.management.model.entity.PointHistory</class>
        <class>com.cinema.management.model.entity.ShiftReport</class>

        <properties>
            <!-- Database Connection -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://127.0.0.1:3306/CinemaDB?useSSL=false&amp;serverTimezone=Asia/Ho_Chi_Minh&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="25032005"/>

            <!-- HikariCP Connection Pool -->
            <property name="hibernate.connection.provider_class"
                      value="org.hibernate.hikaricp.internal.HikariCPConnectionProvider"/>
            <property name="hibernate.hikari.minimumIdle" value="5"/>
            <property name="hibernate.hikari.maximumPoolSize" value="20"/>
            <property name="hibernate.hikari.idleTimeout" value="30000"/>

            <!-- Hibernate Settings -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
