' ---------- Domain relationships ----------
Movie "1" <-- "0..*" ShowTime : movie
Room "1" <-- "0..*" ShowTime : room

Room "1" <-- "0..*" Seat : room
SeatType "1" <-- "0..*" Seat : seatType

ShowTime "1" <-- "0..*" BookingSeat : showTime
Seat "1" <-- "0..*" BookingSeat : seat
Invoice "1" <-- "0..*" BookingSeat : invoice

ShowTime "1" <-- "0..*" SeatLock : showTime
Seat "1" <-- "0..*" SeatLock : seat
User "1" <-- "0..*" SeatLock : lockedBy

Invoice "1" <-- "0..*" OrderDetail : invoice
Product "1" <-- "0..*" OrderDetail : product

User "1" <-- "0..*" Invoice : user
User "0..1" <-- "0..*" Invoice : approvedBy
Customer "0..1" <-- "0..*" Invoice : customer
Promotion "0..1" <-- "0..*" Invoice : promotion

Invoice "1" <-- "0..*" Payment : payments
Invoice "0..1" <-- "0..*" PointHistory : invoice
Customer "1" <-- "0..*" PointHistory : customer

Role "1" <-- "0..*" User : role
User "1" <-- "0..*" AuditLog : changedBy
User "1" <-- "0..*" ShiftReport : user
User "0..1" <-- "0..*" ShiftReport : approvedBy
Customer --> MemberTier : uses

Movie "1" <-- "0..*" MovieGenre : movieGenres
Genre "1" <-- "0..*" MovieGenre : movieGenres
Movie "1" <-- "0..*" Promotion : applyToMovie

' ---------- keep columns ----------
VIEW -[hidden]right-> CTRL
CTRL -[hidden]right-> SRV
SRV -[hidden]right-> REPO
REPO -[hidden]right-> DOMAIN

' ---------- align top ----------
LoginFrame -[hidden]right-> AuditLogController
AuditLogController -[hidden]right-> IAuditLogService
IAuditLogService -[hidden]right-> AuditLogRepository
AuditLogRepository -[hidden]right-> MemberTier
@enduml
