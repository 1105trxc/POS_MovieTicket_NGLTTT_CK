@startuml act_them_khach_hang


title Activity Diagram - Đăng ký thành viên

start
:Nhân viên chọn ngữ cảnh thao tác;
if (Thực hiện ở bước thanh toán?) then (Có)
  :Nhập SĐT thành viên trên màn hình thanh toán;
  if (Khách hàng đã tồn tại?) then (Có)
    :Hiển thị thông tin thành viên\nđể tiếp tục thanh toán;
    stop
  else (Chưa tồn tại)
    :Nhân viên chọn "Đăng ký mới";
  endif
else (Không)
  :Nhân viên mở giao diện Thêm Khách Hàng Mới;
endif

repeat
  :Nhập thông tin khách hàng\n(Họ tên, Số điện thoại, Email);
  if (Họ tên trống?) then (Có)
    :Hiển thị lỗi\n"Họ tên không được để trống";
  elseif (Số điện thoại sai định dạng?) then (Có)
    :Hiển thị lỗi\n"Số điện thoại không hợp lệ";
  elseif (Số điện thoại đã tồn tại trong DB?) then (Có)
    :Hiển thị lỗi\n"Số điện thoại đã được đăng ký";
  else (Hợp lệ)
  endif
repeat while (Có lỗi?) is (Có) not (Không)

:Nhân viên nhấn "Lưu";
if (Lưu thành công?) then (Có)
  :Hiển thị "Thêm khách hàng thành công!";
  if (Đang ở bước thanh toán?) then (Có)
    :Tự động điền thành viên mới vào hóa đơn;
    :Nhân viên tiếp tục thanh toán;
  else (Không)
    :Nhân viên thấy khách hàng mới trong danh sách;
  endif
else (Lỗi)
  :Hiển thị thông báo chưa lưu được\nđể nhập lại thông tin;
endif

stop
@enduml
